# =================================================================
# CONFIGURACIÓN GENERAL DEL SISTEMA SOOP MAIL
# =================================================================

# Entorno de ejecución: 'dev' (desarrollo) o 'prod' (producción)
# Esto determina qué archivo backend/.env.xxx se cargará.
APP_ENV=dev

# Configuración de Seguridad y Debug
SECRET_KEY=dev-secret-key-change-in-production-12345
FLASK_ENV=development
DEBUG=True

# -----------------------------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS (MYSQL)
# -----------------------------------------------------------------
# Estas variables se usan para construir la URL de conexión automáticamente.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=12345
MYSQL_DATABASE=soop_mail_admin

# Para usar conexión por Socket (opcional en Linux):
# MYSQL_UNIX_SOCKET=/var/run/mysqld/mysqld.sock

# -----------------------------------------------------------------
# CONFIGURACIÓN DE CORREO (DOVECOT / POSTFIX)
# -----------------------------------------------------------------
# El archivo de usuarios (passwd-file de Dovecot)
SOOP_MAIL_USERS_FILE=/etc/dovecot/users

# Base de los correos (donde están las carpetas de dominios)
SOOP_MAIL_BASE=/var/mail/vhosts

# UID/GID para los archivos de correo (comúnmente el usuario 'vmail')
SOOP_MAIL_VMAIL_UID=5000
SOOP_MAIL_VMAIL_GID=5000

# Seguridad
SESSION_COOKIE_SECURE=False
DEVELOPMENT=True
